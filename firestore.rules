rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the current user is an admin:
    // Either their Firestore role field is 'admin' OR their email is the known admin email.
    // The email check avoids the chicken-and-egg problem of needing to read a document
    // that may not exist yet, and ensures the admin can always manage the portal.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@ceylo.com' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }
    
    // Helper to check role
    function hasRole(role) {
      return isSignedIn() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
    }

    // Bookings
    match /bookings/{bookingId} {
      allow create: if hasRole('tourist');
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId 
                || (hasRole('driver') && (resource.data.status == 'pending' || resource.data.driverId == request.auth.uid)));
      allow update: if hasRole('driver') || request.auth.uid == resource.data.userId;
    }

    // Vendors
    match /vendors/{vendorId} {
      allow read: if true;
      allow write: if hasRole('vendor') && request.auth.uid == vendorId;
    }

    // SOS Alerts
    match /sos_alerts/{alertId} {
      allow create: if true; // Allow emergency alerts even if not signed in
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        hasRole('admin') || 
        hasRole('guide') || 
        hasRole('driver')
      );
    }

    // Destinations & Events
    match /destinations/{id} { 
      allow read: if true; 
      allow write: if true;
    }
    match /cultural_events/{id} { 
      allow read: if true; 
      allow write: if true;
    }
  }
}

