rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@ceylo.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    function hasRole(role) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Users collection - vendor role update allowed
    match /users/{uid} {
      allow read: if request.auth != null && 
        (request.auth.uid == uid || 
         isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && 
        (request.auth.uid == uid || 
         isAdmin());
    }

    // Bookings (legacy, read by drivers)
    match /bookings/{bookingId} {
      allow create: if hasRole('tourist');
      allow read:   if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid == resource.data.driverId ||
        request.auth.uid == resource.data.vendorId ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        hasRole('driver') || hasRole('tourist') ||
        isAdmin()
      );
    }

    // Vendors collection
    match /vendors/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && 
        (request.auth.uid == uid || 
         isAdmin());
      allow delete: if request.auth != null && 
        isAdmin();
    }

    // Vendor subcollections
    match /vendors/{uid}/services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.uid == uid || 
         isAdmin());
    }

    match /vendors/{uid}/products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && 
        (request.auth.uid == uid || 
         isAdmin());
    }

    match /vendors/{uid}/orders/{orderId} {
      allow read: if request.auth != null && 
        (request.auth.uid == uid || 
         isAdmin());
      allow write: if request.auth != null;
    }

    // Orders (global collection)
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && (
        request.auth.uid == resource.data.vendorId ||
        request.auth.uid == resource.data.touristId ||
        isAdmin()
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.vendorId ||
        request.auth.uid == resource.data.touristId ||
        isAdmin()
      );
      allow list: if request.auth != null;
    }

    // Chats
    match /chats/{chatId} {
      allow read, write: if request.auth != null;

      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // SOS Alerts
    match /sos_alerts/{alertId} {
      allow create: if true;
      allow read:   if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        hasRole('admin') || hasRole('guide') || hasRole('driver')
      );
    }

    // Destinations & Events (public read, admin write)
    match /destinations/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /cultural_events/{id} {
      allow read:  if true;
      allow write: if isAdmin() || isSignedIn();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Itineraries
    match /itineraries/{itineraryId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Tours
    match /tours/{tourId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'guide'];
    }

    // EmergencyLogs
    match /EmergencyLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if true;
    }
  }
}
